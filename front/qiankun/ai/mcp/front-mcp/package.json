{
  "name": "@lm/mcp-server",
  "version": "1.0.0",
  "description": "LM ai tools MCP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "pnpm run build && node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector --config ./inspector.json",
    "start:watch": "nodemon --watch src --ext ts --exec \"pnpm run build && node dist/index.js\"",
    "build": "tsc && tsc-alias",
    "call-hello": "node scripts/call-hello.mjs",
    "call-get-swagger": "node scripts/call-get-swagger.mjs",
    "call-create-api": "node scripts/call-create-api.mjs",
    "call-create-ui": "node scripts/call-create-ui.mjs",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.56.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}